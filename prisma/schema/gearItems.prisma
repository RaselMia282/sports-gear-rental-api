model GearItem{
  id String @id @default(uuid())
  title String 
  description String
  brand String
  stockQuantity Int
  pricePerDay Int
  availableQuantity Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  providerId String
  provider User @relation(fields: [providerId],references: [id])

  @@map("gear_items")
  

}